{
  "name": "@fkui/user-lib-vue",
  "version": "1.5.9",
  "description": "Vue implementation of custom user components",
  "keywords": [
    "fkui",
    "designsystem",
    "vue"
  ],
  "homepage": "https://forsakringskassan.github.io/designsystem-user-lib/",
  "bugs": "https://github.com/Forsakringskassan/designsystem-user-lib/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/designsystem-user-lib.git",
    "directory": "packages/vue"
  },
  "license": "MIT",
  "author": "Försäkringskassan",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.esm.js",
      "require": "./dist/cjs/index.cjs.js"
    },
    "./htmlvalidate": "./htmlvalidate/index.cjs"
  },
  "main": "dist/cjs/index.cjs.js",
  "module": "dist/esm/index.esm.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "htmlvalidate"
  ],
  "scripts": {
    "prebuild": "run-s clean",
    "build": "run-s build:lib build:dts build:api",
    "build:api": "fk-api-extractor --patch-augmentations --patch-declare-var-vls api-extractor.json",
    "build:dts": "vue-tsc -b",
    "build:lib": "fk-build-vue-lib",
    "clean": "rimraf -g *.tsbuildinfo coverage dist public temp test-results",
    "start": "vite --"
  },
  "devDependencies": {
    "@fkui/design": "6.52.2",
    "@fkui/icon-lib-default": "6.52.2",
    "@fkui/logic": "6.52.2",
    "@fkui/theme-default": "6.52.2",
    "@fkui/tsconfig": "6.52.0",
    "@fkui/user-lib-design": "1.5.9",
    "@fkui/vue": "6.52.2",
    "@forsakringskassan/vite-lib-config": "5.2.0",
    "@forsakringskassan/vitest-config": "2.5.0",
    "@forsakringskassan/vitest-config-jsdom": "2.5.0",
    "@vue/test-utils": "2.4.11",
    "flush-promises": "1.0.2",
    "html-validate": "11.5.6",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "vue": "3.5.39"
  },
  "peerDependencies": {
    "@babel/runtime": "^7",
    "@fkui/design": "^6.0.0",
    "@fkui/icon-lib-default": "^6.0.0",
    "@fkui/logic": "^6.0.0",
    "@fkui/theme-default": "^6.0.0",
    "@fkui/user-lib-design": "^1",
    "@fkui/vue": "^6.0.0",
    "core-js": "^3.24",
    "vue": "^3"
  },
  "engines": {
    "node": "^22.16 || >= 24",
    "npm": ">= 7"
  }
}
