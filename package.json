{
  "name": "@fkui/user-lib-monorepo",
  "version": "1.5.4",
  "private": true,
  "description": "fkui custom user monorepo",
  "homepage": "https://forsakringskassan.github.io/designsystem-user-lib/",
  "bugs": "https://github.com/Forsakringskassan/designsystem-user-lib/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/designsystem-user-lib.git"
  },
  "license": "MIT",
  "author": "Försäkringskassan",
  "main": "index.js",
  "files": [],
  "workspaces": [
    "docs",
    "packages/*"
  ],
  "scripts": {
    "build": "lerna run build",
    "build:docs": "node generate-docs.mjs && lerna run build:docs && npm run build:public",
    "build:public": "html-validate --formatter stylish,codeframe --config .htmlvalidate-public.js public",
    "preclean": "rimraf -g .eslintcache *.tgz public temp test-results",
    "clean": "npm run --workspaces --if-present clean",
    "design": "npm run --workspace packages/design --",
    "eslint": "eslint --cache .",
    "eslint:fix": "eslint --fix .",
    "html-validate": "html-validate --formatter stylish,codeframe --ext md,html,vue docs packages/*/src",
    "lerna": "lerna",
    "link-all": "lerna exec npm link",
    "lint": "run-s prettier:check eslint stylelint html-validate",
    "lint:fix": "run-s prettier:write eslint:fix stylelint:fix",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "start": "node docs/serve.mjs public",
    "stylelint": "stylelint \"packages/*/src/**/*.scss\"",
    "stylelint:fix": "npm run stylelint -- --fix",
    "pretest": "npm run lint",
    "test": "lerna run test",
    "vue": "npm run --workspace packages/vue --"
  },
  "commitlint": {
    "extends": "@forsakringskassan/commitlint-config/no-jira"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-monorepo-config"
  },
  "stylelint": {
    "extends": [
      "@forsakringskassan/stylelint-config",
      "@fkui/design/stylelint/recommended"
    ]
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@fkui/date": "6.49.1",
    "@fkui/vue": "6.49.1",
    "@forsakringskassan/commitlint-config": "3.6.7",
    "@forsakringskassan/docs-generator": "3.1.1",
    "@forsakringskassan/docs-live-example": "3.0.0",
    "@forsakringskassan/eslint-config": "15.0.10",
    "@forsakringskassan/eslint-config-cli": "15.0.0",
    "@forsakringskassan/eslint-config-jest": "15.0.0",
    "@forsakringskassan/eslint-config-typescript": "15.0.13",
    "@forsakringskassan/eslint-config-typescript-typeinfo": "15.0.13",
    "@forsakringskassan/eslint-config-vue": "15.0.13",
    "@forsakringskassan/jest-config": "29.11.2",
    "@forsakringskassan/jest-config-vue": "29.9.0",
    "@forsakringskassan/prettier-config": "3.7.1",
    "@forsakringskassan/stylelint-config": "3.4.3",
    "@forsakringskassan/vite-lib-config": "5.0.2",
    "@html-validate/release-scripts": "7.2.4",
    "@types/estree": "1.0.9",
    "@types/glob": "9.0.0",
    "@types/jest": "29.5.14",
    "@types/lodash": "4.17.24",
    "@types/node": "22.19.21",
    "@vue/server-renderer": "3.5.35",
    "autoprefixer": "10.5.0",
    "cli-table": "0.3.11",
    "core-js": "3.49.0",
    "esbuild": "0.28.1",
    "flush-promises": "1.0.2",
    "fs-extra": "11.3.5",
    "glob": "13.0.6",
    "highlight.js": "11.11.1",
    "html-validate": "11.5.3",
    "html-validate-markdown": "6.0.0",
    "html-validate-vue": "9.3.1",
    "is-ci": "4.1.0",
    "lerna": "9.0.7",
    "mocha-junit-reporter": "2.2.1",
    "mocha-multi-reporters": "1.5.1",
    "npm-pkg-lint": "5.1.6",
    "npm-run-all2": "9.0.1",
    "postcss": "8.5.15",
    "rimraf": "6.1.3",
    "sass": "1.100.0",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vue": "3.5.35",
    "vue-tsc": "3.3.4"
  },
  "engines": {
    "node": "^22.16 || >= 24",
    "npm": ">= 7"
  }
}
